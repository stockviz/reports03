select(STRAT_TITLE, PMS_NAME, ASSET_CLASS, AUM) |>
mutate(AUM = round(as.numeric(AUM), 0), more = "") |>
filter(AUM > 0) |>
rename(STRATEGY = STRAT_TITLE, PMS = PMS_NAME) |>
arrange(desc(AUM))
